# =============================================================================
# SPECTRABREAST — .gitignore
# =============================================================================

# Dati di input (file pesanti, non versionare)
data/input/

# Output generati (si ricalcolano, non versionare)
data/output/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Ambienti virtuali
.venv/
venv/
env/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb

# File temporanei e di log
*.log
*.tmp

# immagini
.jpeg
.png
